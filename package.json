{
  "name": "skpkg",
  "version": "1.0.0",
  "description": "Install skills from GitHub repos into Claude Desktop",
  "bin": {
    "skpkg": "dist/index.js"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --format esm",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": ["claude", "skills", "cli"],
  "author": "",
  "license": "MIT",
  "type": "module",
  "files": ["dist"],
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
