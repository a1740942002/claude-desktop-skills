{
  "name": "claude-desktop-skills",
  "version": "0.0.1",
  "description": "Install skills from GitHub repos into Claude Desktop",
  "bin": {
    "claude-desktop-skills": "dist/index.js"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --format esm",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude",
    "skills",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
